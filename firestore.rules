rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────
    //  ヘルパー関数
    // ────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/app_config/user_roles).data[request.auth.uid] == 'admin';
    }
    function hasRole() {
      return request.auth != null
        && get(/databases/$(database)/documents/app_config/user_roles).data[request.auth.uid] in ['admin','foreman','keiri'];
    }
    function isAuthenticated() {
      return request.auth != null;
    }

    // ────────────────────────────────────────
    //  ユーザー管理・ロール設定
    // ────────────────────────────────────────
    match /app_config/user_registry {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    match /app_config/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ────────────────────────────────────────
    //  出面データ
    // ────────────────────────────────────────

    // ヘルパー: 既存マップフィールドが「非空 → 空」に書き換えられていないか
    // (2026-05-07 事故対策。setDoc({field:{}}, {merge:true}) のような罠を server 側で拒否する)
    function notWipingMap(fieldName) {
      return !(fieldName in resource.data)
          || resource.data[fieldName].size() == 0
          || !(fieldName in request.resource.data)
          || request.resource.data[fieldName].size() > 0;
    }

    // マスターデータ（main）：新アプリ（パスワード認証）からも読み書き可能
    // 重要マップを空に置換する書き込みは拒否。
    // 2026-05-08 強化: massign / userPasswords / siteWorkDays / workDays / locks / evaluationSettings も追加。
    //   userPasswords が空に上書きされると全社員ログイン不能になるため特に重要。
    match /demmen/main {
      allow read: if true;
      allow create: if true;
      allow delete: if false;  // main ドキュメント自体の削除を禁止
      allow update: if notWipingMap('workers')
                 && notWipingMap('sites')
                 && notWipingMap('plData')
                 && notWipingMap('homeLeaves')
                 && notWipingMap('subcons')
                 && notWipingMap('assign')
                 && notWipingMap('massign')
                 && notWipingMap('mforeman')
                 && notWipingMap('userPasswords')
                 && notWipingMap('siteWorkDays')
                 && notWipingMap('workDays')
                 && notWipingMap('locks')
                 && notWipingMap('evaluationSettings');
    }
    // 請求額データ（billing_data）：ロール持ちのみ書き込み
    match /demmen/billing_data {
      allow read: if isAuthenticated();
      allow write: if hasRole();
    }
    // 月別出面データ（att_YYYYMM）+ 道具代補助（toolBudget）— 新アプリ（トークン認証）からも読み書き可能
    // 既存の d / sd マップを空に置換する書き込みは拒否（2026-05-07 事故と同種の事故防止）
    match /demmen/{docId} {
      allow read: if true;
      allow create: if docId.matches('att_[0-9]{6}') || docId == 'toolBudget';
      // delete は禁止（過去に att_ を delete するコードはなく、誤操作・攻撃を防ぐ）
      allow delete: if false;
      allow update: if (docId.matches('att_[0-9]{6}') || docId == 'toolBudget')
                 && notWipingMap('d')
                 && notWipingMap('sd');
    }

    // ────────────────────────────────────────
    //  有給申請（スマホからスタッフが申請するため非認証 read/write 必要）
    //  ⚠️ 偽申請の可能性は API 側のサーバ検証で防ぐ（職長承認・最終承認の二段階）
    // ────────────────────────────────────────
    match /leaveRequests/{docId} {
      allow read, write: if true;
    }

    // ────────────────────────────────────────
    //  長期休暇（帰国）申請（同上）
    // ────────────────────────────────────────
    match /homeLongLeave/{docId} {
      allow read, write: if true;
    }

    // ────────────────────────────────────────
    //  ログイン履歴
    // ────────────────────────────────────────
    match /login_logs/{logId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // ────────────────────────────────────────
    //  就業カレンダーシステム
    // ────────────────────────────────────────
    // カレンダー割当データ
    match /workerCalendar/{docId} {
      allow read, write: if true;
    }

    // カレンダー署名データ
    match /calendarSign/{docId} {
      allow read, write: if true;
    }

    // カレンダーパターン定義
    match /calendarPatterns/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // 現場別カレンダー割当データ
    match /siteCalendar/{docId} {
      allow read, write: if true;
    }

    // 出面承認データ（新アプリ用）
    // ⚠️ 2026-05-08 強化: 2段階承認 (foreman/final) のフィールド消失防止
    //   foreman を空マップに置換すると承認失効、final も同様
    match /attendanceApprovals/{docId} {
      allow read: if true;
      allow create: if true;
      allow delete: if true;  // 承認解除で削除されることがある
      allow update: if notWipingMap('foreman') && notWipingMap('final');
    }

    // ────────────────────────────────────────
    //  HR評価データ
    // ────────────────────────────────────────
    // 評価セッションは reviews 配列に各評価者が追記するので、空マップ化は要注意
    match /evaluations/{docId} {
      allow read: if true;
      allow create: if true;
      allow delete: if false;  // 評価データの削除は禁止（履歴を残す）
      allow update: if true;
    }

    // ────────────────────────────────────────
    //  アクティビティログ
    // ────────────────────────────────────────
    match /activityLog/{docId} {
      allow read, write: if true;
    }

    // ────────────────────────────────────────
    //  アクセスログ
    // ────────────────────────────────────────
    match /accessLog/{docId} {
      allow read, write: if true;
    }

    // ────────────────────────────────────────
    //  バックアップスナップショット (PITR 代替)
    //  /api/backup/snapshot から日次で書き込まれる
    //  ⚠️ Firebase Admin SDK 未導入のため API も client SDK を使う。
    //     したがって client/server を rules で区別できず、書き込み許可が必要。
    //     代わりに schema 制約で偽データ注入を抑止する:
    //       - data フィールドが必須（中身があるバックアップしか書けない）
    //       - sourceId が "demmen/" で始まる
    //     これで「空オブジェクトの偽バックアップ」攻撃は防げる。
    // ────────────────────────────────────────
    match /backups/{docId} {
      allow read: if true;
      allow create: if request.resource.data.sourceId is string
                 && request.resource.data.sourceId.matches('demmen/.*')
                 && request.resource.data.data is map
                 && request.resource.data.data.size() > 0;
      allow update: if false;  // バックアップは追記のみ、変更は禁止
      allow delete: if true;   // 古いスナップショットの自動削除
    }
  }
}
